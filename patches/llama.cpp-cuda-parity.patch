# Optional strict CUDA numerical parity controls for llama.cpp.

diff --git a/ggml/src/ggml-cuda/CMakeLists.txt b/ggml/src/ggml-cuda/CMakeLists.txt
index b54d4a6..cf9ab74 100644
--- a/ggml/src/ggml-cuda/CMakeLists.txt
+++ b/ggml/src/ggml-cuda/CMakeLists.txt
@@ -1,5 +1,7 @@
 cmake_minimum_required(VERSION 3.18)  # for CMAKE_CUDA_ARCHITECTURES
 
+option(GGML_CUDA_FAST_MATH "Use CUDA fast math approximations" ON)
+
 find_package(CUDAToolkit)
 
 if (CUDAToolkit_FOUND)
@@ -193,7 +195,11 @@ if (CUDAToolkit_FOUND)
 
     set(CUDA_CXX_FLAGS "")
 
-    set(CUDA_FLAGS -use_fast_math -extended-lambda)
+    set(CUDA_FLAGS -extended-lambda)
+
+    if (GGML_CUDA_FAST_MATH)
+        list(APPEND CUDA_FLAGS -use_fast_math)
+    endif()
 
     if (GGML_CUDA_DEBUG)
         list(APPEND CUDA_FLAGS -lineinfo)
diff --git a/ggml/src/ggml-cuda/common.cuh b/ggml/src/ggml-cuda/common.cuh
index 1081750..9466c3b 100644
--- a/ggml/src/ggml-cuda/common.cuh
+++ b/ggml/src/ggml-cuda/common.cuh
@@ -1449,7 +1449,10 @@ struct ggml_backend_cuda_context {
         if (cublas_handles[device] == nullptr) {
             ggml_cuda_set_device(device);
             CUBLAS_CHECK(cublasCreate(&cublas_handles[device]));
-            CUBLAS_CHECK(cublasSetMathMode(cublas_handles[device], CUBLAS_TF32_TENSOR_OP_MATH));
+            const cublasMath_t math_mode = getenv("GGML_CUDA_FORCE_CUBLAS_COMPUTE_32F")
+                ? CUBLAS_DEFAULT_MATH
+                : CUBLAS_TF32_TENSOR_OP_MATH;
+            CUBLAS_CHECK(cublasSetMathMode(cublas_handles[device], math_mode));
         }
         return cublas_handles[device];
     }
diff --git a/ggml/src/ggml-cuda/mmf.cu b/ggml/src/ggml-cuda/mmf.cu
index aad4c34..8d50798 100644
--- a/ggml/src/ggml-cuda/mmf.cu
+++ b/ggml/src/ggml-cuda/mmf.cu
@@ -132,6 +132,10 @@ void ggml_cuda_mul_mat_f(ggml_backend_cuda_context & ctx, const ggml_tensor * sr
 
 bool ggml_cuda_should_use_mmf(enum ggml_type type, int cc, int warp_size, const int64_t * src0_ne,
         const size_t * src0_nb, const int src1_ncols, bool mul_mat_id) {
+#ifdef GGML_CUDA_FORCE_CUBLAS
+    return false;
+#endif
+
     if (ggml_is_quantized(type)) {
         return false;
     }
diff --git a/ggml/src/ggml-cuda/mmvf.cu b/ggml/src/ggml-cuda/mmvf.cu
index d914720..2012b79 100644
--- a/ggml/src/ggml-cuda/mmvf.cu
+++ b/ggml/src/ggml-cuda/mmvf.cu
@@ -777,6 +777,10 @@ void ggml_cuda_op_mul_mat_vec_f(
 }
 
 bool ggml_cuda_should_use_mmvf(enum ggml_type type, int cc, const int64_t * src0_ne, const size_t * src0_nb, int64_t ne11) {
+#ifdef GGML_CUDA_FORCE_CUBLAS
+    return false;
+#endif
+
     if (src0_ne[0] % 2 != 0) {
         return false;
     }
